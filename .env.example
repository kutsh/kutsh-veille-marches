# --- Analyse (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-...
# Modèle d'analyse (défaut openai/gpt-4o-mini)
VEILLE_MODEL=openai/gpt-4o-mini

# --- CRM Twenty (Signal MARCHE_PUBLIC) ---
TWENTY_API_KEY=...
TWENTY_BASE_URL=https://twenty.kutsh.fr

# --- Basecamp : choisir UNE des deux voies ---
# Voie 1 (recommandée, sans OAuth) : Campfire via lines_url signée
BASECAMP_CHATBOT_LINES_URL=https://3.basecamp.com/XXXX/integrations/XXXX/buckets/46486516/chats/XXXX/lines
# Voie 2 (message riche dans le projet) : API Basecamp
# BASECAMP_ACCESS_TOKEN=...
# BASECAMP_ACCOUNT_ID=XXXXXXXX
# BASECAMP_PROJECT_ID=46486516

# --- État : S3 (sinon fichier sur volume /data) ---
# S3_BUCKET=kutsh-veille
# S3_ENDPOINT=https://fsn1.your-objectstorage.com
# S3_REGION=fsn1
# S3_ACCESS_KEY=...        (ou DECI_S3_ACCESS_KEY)
# S3_SECRET_KEY=...        (ou DECI_S3_SECRET_KEY)
# S3_STATE_KEY=veille-marches/state.json
# Sinon, état sur volume Coolify :
STATE_FILE=/data/veille-marches-state.json

# --- Réglages ---
# VEILLE_TERMS="autorisations d'urbanisme;droit des sols;logiciel gestion dossiers"
# VEILLE_MAX_RESULTS=30
# VEILLE_DRY_RUN=false
# VEILLE_TIMEOUT=60
